{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nanobot Desktop",
  "version": "0.1.0",
  "identifier": "com.nanobot.desktop",
  "build": {
    "beforeDevCommand": "set NANOBOT_DESKTOP_DATA_DIR=./.desktop-data && python ../run_backend.py",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:18791",
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "Nanobot Desktop",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [
      "../dist/backend/nanobot-desktop-backend/**/*",
      "../dist/runtime/nanobot-runtime/**/*"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hw7622/nanobot-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "NANOBOT_DESKTOP_UPDATER_PUBKEY_PLACEHOLDER"
    }
  }
}
