{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nanobot Desktop",
  "version": "0.4.0",
  "identifier": "com.nanobot.desktop",
  "build": {
    "beforeDevCommand": ".\\run_backend_dev.bat",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:18791",
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "Nanobot Desktop",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [
      "../dist/backend/nanobot-desktop-backend/**/*",
      "../dist/runtime/nanobot-runtime/**/*"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hw7622/nanobot-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxMUU1NTUzN0E1MzUwQzIKUldUQ1VGTjZVMVVlNGVyMUoxblIvZGovM0I4aE1XRFVQUE4xZ2dCUU0ydUxqSVplNmdnUXlaWWwK"
    }
  }
}
