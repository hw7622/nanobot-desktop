{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-window-remote-dev",
  "description": "Allow the main dev window loaded from the local desktop backend to use Tauri IPC.",
  "windows": ["main"],
  "urls": [
    "http://127.0.0.1:18791/*",
    "http://localhost:18791/*"
  ],
  "permissions": [
    "core:default",
    "updater:default"
  ]
}
